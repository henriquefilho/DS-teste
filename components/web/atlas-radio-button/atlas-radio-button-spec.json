    {
      "name": "name",
      "type": "string",
      "values": [],
      "default": "",
      "required": false,
      "description": "Atributo name para agrupamento em formulários HTML"
    },
    {
      "name": "value",
      "type": "string",
      "values": [],
      "default": "",
      "required": false,
      "description": "Atributo value para formulários HTML"
    }
  ],
  "states": [
