    {
      "name": "state",
      "type": "enum",
      "values": ["default", "read-only", "disabled", "error"],
      "default": "default",
      "required": false,
      "description": "Estado do radio: default (interativo), read-only (apenas leitura), disabled (desabilitado), error (erro de validação)"
    },
    {
      "name": "label",
      "type": "string",
      "values": [],
      "default": "",
      "required": false,
